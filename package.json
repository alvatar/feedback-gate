    "deploy:apps-script": "./scripts/deploy-apps-script.sh",
    "deploy:worker": "./scripts/deploy-worker.sh",
    "deploy": "./scripts/deploy-all.sh"
  },
  "devDependencies": {
    "typescript": "^5.9.2"
  }
}
