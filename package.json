{
  "name": "feedback-gate",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Minimal embeddable TypeScript feedback modal wired to Google Sheets.",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "tsc -p tsconfig.json --noEmit",
